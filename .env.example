# ============================================================
# SGPP - Variables de Entorno (Desarrollo Local)
# ============================================================
# Copia este archivo como .env y ajusta los valores a tu entorno.
#   cp .env.example .env       (Linux/Mac)
#   copy .env.example .env     (Windows CMD)
# ============================================================

# ----- Base de Datos (PostgreSQL) -----
POSTGRES_DB=sgpp_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5434

# ----- pgAdmin (Interfaz web para PostgreSQL) -----
PGADMIN_DEFAULT_EMAIL=admin@sgpp.dev
PGADMIN_DEFAULT_PASSWORD=admin

# ----- Backend (Spring Boot) -----
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8082

# ----- JWT -----
# Clave Base64 para firmar tokens (misma default usada en perfil local).
# En produccion cambiar por un valor seguro generado con: openssl rand -base64 64
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# ----- Frontend (Vite / React) -----
VITE_API_BASE_URL=http://localhost:8082/api/v1
